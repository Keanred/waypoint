{
  "name": "waypoint",
  "version": "0.0.1",
  "description": "Reminder & task deadline tracker",
  "private": true,
  "workspaces": [
    "server",
    "client",
    "schemas"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=server & npm run dev --workspace=client; wait",
    "build": "npm run build --workspace=schemas && npm run build --workspace=server && npm run build --workspace=client",
    "test": "npm test --workspace=server && npm test --workspace=client",
    "db:generate": "npm run db:generate --workspace=server",
    "db:migrate": "npm run db:migrate --workspace=server",
    "db:push": "npm run db:push --workspace=server",
    "db:studio": "npm run db:studio --workspace=server"
  },
  "devDependencies": {
    "drizzle-orm": "^0.45.1"
  }
}

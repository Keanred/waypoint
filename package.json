{
  "name": "waypoint",
  "version": "0.0.1",
  "description": "Reminder & task deadline tracker",
  "private": true,
  "workspaces": [
    "server",
    "client",
    "schemas"
  ],
  "scripts": {
    "build": "npm run build --workspace=schemas && npm run build --workspace=server && npm run build --workspace=client",
    "lint": "eslint client server schemas --max-warnings 0",
    "format": "prettier . --write"
  },
  "devDependencies": {
    "drizzle-orm": "^0.45.1",
    "jiti": "^2.4.2",
    "prettier-plugin-organize-imports": "^4.3.0",
    "typescript-eslint": "^8.46.1"
  },
  "dependencies": {
    "eslint": "^10.1.0",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.1"
  }
}

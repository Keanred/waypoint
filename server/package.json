{
  "name": "waypoint-server",
  "version": "0.0.1",
  "description": "Waypoint backend server",
  "private": true,
  "type": "module",
  "exports": "./dist/index.js",
  "scripts": {
    "dev": "if [ -f .env ]; then node --env-file .env --import tsx --watch src/main.ts; else node --import tsx --watch src/main.ts; fi",
    "build": "tsc",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate --config=drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config=drizzle.config.ts",
    "db:push": "drizzle-kit push --config=drizzle.config.ts",
    "db:studio": "drizzle-kit studio --config=drizzle.config.ts"
  },
  "dependencies": {
    "@waypoint/schemas": "file:../schemas",
    "@neondatabase/serverless": "^0.10.0",
    "@types/cors": "^2.8.19",
    "cors": "^2.8.6",
    "drizzle-orm": "^0.45.1",
    "express": "^5.2.1",
    "node-cron": "^3.0.3",
    "postgres": "^3.4.8",
    "resend": "^3.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.5",
    "@types/supertest": "^6.0.2",
    "drizzle-kit": "^0.31.10",
    "supertest": "^7.1.3",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.1.3"
  }
}
